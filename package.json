{
  "name": "trust-city-autonomous-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n ORCH,CLIENT -c cyan,magenta \"npm run dev -w @trust-city/orchestrator\" \"npm run dev -w @trust-city/sim-client\"",
    "dev:orchestrator": "npm run dev -w @trust-city/orchestrator",
    "dev:client": "npm run dev -w @trust-city/sim-client",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w @trust-city/orchestrator"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
