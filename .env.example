# Core runtime
ORCHESTRATOR_PORT=8787
WORLD_SEED=271828

# Operator identity
OPERATOR_PRIVATE_KEY=0xyour_sepolia_private_key_here
OPERATOR_WALLET=0xyour_operator_wallet_address_here
AGENT_ERC8004_ID=agent:erc8004:trust-city-exchange

# Ethereum Sepolia
CHAIN_ID=11155111
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ERC-8004 registries
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDRESS=0x8004CB39f29c09145F24Ad9dDe2A108C1A2cdfC5

# Agent metadata
AGENT_METADATA_URI=https://example.com/agents/trust-city-exchange.json

# Feature flags
ENABLE_ONCHAIN_WRITES=true
# Validation on Sepolia may require an authorized verifier/studio flow.
# The app will probe the registry and disable direct validation writes for the session if this operator is not authorized.
ENABLE_VALIDATION_WRITES=true
ENABLE_REPUTATION_WRITES=true

FEEDBACK_CLIENT_PRIVATE_KEY=0x...
FEEDBACK_CLIENT_WALLET=0x...
